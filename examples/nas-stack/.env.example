# ============================================================================
# moxian-nas-stack 配置
# 复制为 .env 后修改 所有敏感值（带 CHANGEME）必须改
# docker compose 启动时自动加载本文件
# ============================================================================

# ---- 基础 ----
TZ=Asia/Shanghai
PUID=1000           # 容器内运行用户 ID 改成你的 id -u 输出
PGID=1000           # 容器内运行组 ID   改成你的 id -g 输出
HOST_IP=192.168.1.10  # NAS 在局域网的 IP 用于应用间互相引用

# ---- 数据路径（bootstrap.sh 会自动创建）----
# 所有应用数据和用户文件都在这下面 迁移时只需 rsync 此目录
DATA_ROOT=/mnt/pool

# ---- Immich ----
IMMICH_VERSION=release
IMMICH_PORT=2283
IMMICH_DB_PASSWORD=CHANGEME-immich-db-strong-password

# ---- Jellyfin ----
JELLYFIN_PORT=8096

# ---- Syncthing ----
SYNCTHING_UI_PORT=8384

# ---- Vaultwarden ----
VAULTWARDEN_PORT=8080
# 生成方法：openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=CHANGEME-use-openssl-rand-base64-48
# 首次注册完管理员后建议改为 false 防止他人注册
VAULTWARDEN_SIGNUPS_ALLOWED=true

# ---- qBittorrent ----
QBIT_UI_PORT=8081
