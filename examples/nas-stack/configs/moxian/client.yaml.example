# moxian-p2p NAS 端配置（TUN + mesh 模式）
#
# 适用：
#   - Windows / Mac 原生 moxian-gui.exe（推荐，需管理员）
#   - Linux 真机 + docker-compose.moxian.yml overlay（路子 A 只在 Linux 稳定）
#
# 路径：
#   - 容器内：/etc/moxian/client.yaml
#   - 宿主机：examples/nas-stack/configs/moxian/client.yaml
#   - 原生 exe：放 moxian-gui.exe 同目录

# ---- 基础 ----
# 本节点 ID 全局唯一 对端用这个名字找你
node_id: home-nas

# 信令服务器 你自己 VPS 跑的 moxian-server
# 和对端（手机/其他 NAS）必须一致
server: wss://your-signal-vps.example.com:8443
udp:    your-signal-vps.example.com:7000

# 所有节点必须一致 KCP AES 派生密钥 别泄漏
pass: CHANGEME-shared-passphrase

# 标签 方便其他节点识别你 可选
tags:
  - role=nas
  - location=home

# ---- TUN + mesh 核心（透明 vIP 访问）----

# 虚拟 IP auto = 由 server 自动分配（推荐）
# 也可以指定固定 IP 如 10.88.0.2
virtual_ip: auto

# Mesh 自动组网：启动时尝试和 mesh_pool 里所有节点建立 P2P 隧道
mesh: true

# Mesh 预热节点列表 写其他在线节点的 node_id
# 对端也要把你加到他们的 mesh_pool 或者两边都开 mesh 自发现
mesh_pool:
  - phone      # 手机
  # - laptop   # 笔记本
  # - office-pc

# ---- 安全 ----

# 只允许这些对端连入（白名单）空或注释掉 = 接受任意对端
allow_peers:
  - role=owner
  - role=family

# ---- 可选 ----

# 客户端出站限速 字节/秒 0 = 不限
rate_limit: 0

# 详细日志 排障时开
verbose: false
