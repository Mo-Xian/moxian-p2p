# moxian-p2p v2 client 凭据文件示例
# 实际位置：/etc/moxian/client.env (mode 600)
# 由 scripts/install-client.sh 自动生成 不用手抄
#
# v2 设计：客户端只需输 server URL + 邮箱 + 密码 + 节点名
# 启动后自动从 /api/config 拉取所有 P2P 参数（pass / vIP / peers / TUN 设置）
# 不再需要手写 server / udp / pass 等字段

MOXIAN_SERVER=https://your.vps.ip:7788
MOXIAN_EMAIL=you@example.com
MOXIAN_PASSWORD=YourStrongPassword
MOXIAN_NODE=home-nas

# 自签证书时填 -insecure-tls 留空 = 严格 TLS 校验
MOXIAN_INSECURE=-insecure-tls
