<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Android 11+ 查询其他 APP 是否已装 用于服务启动器的 deeplink 唤起 -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <!-- 已知的专业 APP 包名 isInstalled 检查 -->
        <package android:name="org.jellyfin.mobile" />
        <package android:name="dev.jdtech.jellyfin" />
        <package android:name="app.alextran.immich" />
        <package android:name="app.symfonik.music.player" />
    </queries>

    <application
        android:name=".MoxianApplication"
        android:label="moxian-p2p"
        android:icon="@android:drawable/sym_def_app_icon"
        android:theme="@style/Theme.Moxian"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        android:allowBackup="false">

        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- 桌面长按图标快捷菜单 -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- 自动升级用：把下载好的 APK 以 content:// URI 给系统安装器 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <activity
            android:name=".UnlockActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ServiceLauncherActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:label="NAS 服务" />

        <!-- NAS 服务内置客户端 -->
        <activity
            android:name=".WebViewActivity"
            android:exported="false"
            android:parentActivityName=".ServiceLauncherActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:hardwareAccelerated="true"
            android:label="Web" />

        <activity
            android:name=".QBittorrentActivity"
            android:exported="false"
            android:parentActivityName=".ServiceLauncherActivity"
            android:label="qBittorrent" />

        <activity
            android:name=".SyncthingActivity"
            android:exported="false"
            android:parentActivityName=".ServiceLauncherActivity"
            android:label="Syncthing" />

        <activity
            android:name=".AdGuardActivity"
            android:exported="false"
            android:parentActivityName=".ServiceLauncherActivity"
            android:label="AdGuard Home" />

        <activity
            android:name=".ImmichActivity"
            android:exported="false"
            android:parentActivityName=".ServiceLauncherActivity"
            android:label="Immich" />

        <activity
            android:name=".PhotoViewerActivity"
            android:exported="false"
            android:parentActivityName=".ImmichActivity"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:label="查看" />

        <activity
            android:name=".JellyfinActivity"
            android:exported="false"
            android:parentActivityName=".ServiceLauncherActivity"
            android:label="Jellyfin" />

        <activity
            android:name=".NavidromeActivity"
            android:exported="false"
            android:parentActivityName=".ServiceLauncherActivity"
            android:label="Navidrome" />

        <activity
            android:name=".VaultwardenActivity"
            android:exported="false"
            android:parentActivityName=".ServiceLauncherActivity"
            android:label="Vaultwarden" />

        <activity
            android:name=".LoginWizardActivity"
            android:exported="false"
            android:parentActivityName=".ServiceLauncherActivity"
            android:label="批量登录" />

        <service
            android:name=".NavPlayerService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- VpnService 不需要 foregroundServiceType 系统会自动把它当前台服务 -->
        <service
            android:name=".MoxianVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

    </application>

</manifest>
