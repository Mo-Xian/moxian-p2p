<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:padding="12dp">

    <!-- 升级横幅（默认隐藏 检测到新版本时显示）-->
    <TextView
        android:id="@+id/tv_update"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:padding="10dp"
        android:layout_marginBottom="6dp"
        android:textColor="@color/bg"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@color/green"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"/>

    <!-- 状态条 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_card"
        android:padding="10dp">

        <TextView
            android:id="@+id/tv_state_dot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="6dp"/>

        <ProgressBar
            android:id="@+id/pb_connecting"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="6dp"
            android:visibility="gone"
            android:indeterminateTint="@color/accent"
            style="?android:attr/progressBarStyleSmall"/>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/status_idle"
            android:textSize="16sp"
            android:textColor="@color/accent"/>

        <Button
            android:id="@+id/btn_test"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:minWidth="64dp"
            android:paddingHorizontal="10dp"
            android:text="@string/btn_test"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_start_stop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_start"
            android:backgroundTint="@color/accent"
            android:textColor="@color/bg"/>
    </LinearLayout>

    <!-- 配置区（可折叠） -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 配置卡片 -->
            <LinearLayout
                android:id="@+id/config_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_card"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="配置"
                        android:textColor="@color/accent"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btn_qr_scan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="32dp"
                        android:minWidth="64dp"
                        android:paddingHorizontal="8dp"
                        android:text="扫码"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btn_qr_show"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="32dp"
                        android:minWidth="64dp"
                        android:paddingHorizontal="8dp"
                        android:text="分享"
                        android:textSize="12sp"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/et_node_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_node_id"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:text="phone"/>

                <EditText
                    android:id="@+id/et_server"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_server"
                    android:inputType="textUri"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"/>

                <EditText
                    android:id="@+id/et_udp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_udp"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"/>

                <EditText
                    android:id="@+id/et_token"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_token"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"/>

                <EditText
                    android:id="@+id/et_pass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_pass"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"/>

                <EditText
                    android:id="@+id/et_vip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_vip"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:text="auto"/>

                <EditText
                    android:id="@+id/et_forwards"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_forwards"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:maxLines="5"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"/>

                <CheckBox
                    android:id="@+id/cb_mesh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cb_mesh"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:buttonTint="@color/accent"/>

            </LinearLayout>

            <!-- 日志区 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_card"
                android:padding="10dp"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="日志"
                        android:textColor="@color/accent"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btn_copy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="36dp"
                        android:minWidth="64dp"
                        android:paddingHorizontal="10dp"
                        android:text="@string/btn_copy"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btn_clear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="36dp"
                        android:minWidth="64dp"
                        android:paddingHorizontal="10dp"
                        android:text="@string/btn_clear"
                        android:textSize="12sp"/>
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_log"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="240dp"
                        android:fontFamily="monospace"
                        android:textSize="11sp"
                        android:textColor="@color/text_primary"
                        android:background="#00000000"
                        android:paddingTop="4dp"/>
                </HorizontalScrollView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
